<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Localization Assistant | Day 1: The Metacrisis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Lora:ital,wght@0,400;0,700;1,400&display=swap');
        
        :root {
            --earth-900: #1a1512;
            --leaf-600: #3a5a40;
            --leaf-500: #588157;
            --water-500: #34a0a4;
            --clay-600: #8b4513;
            --clay-500: #bc6c25;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fdfaf7;
            color: var(--earth-900);
        }

        .serif { font-family: 'Lora', serif; }

        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(58, 90, 64, 0.1);
        }

        .chat-bubble-user {
            background-color: var(--leaf-500);
            color: white;
            border-radius: 1.5rem 1.5rem 0 1.5rem;
        }

        .chat-bubble-ai {
            background-color: #f1f5f9;
            color: var(--earth-900);
            border-radius: 1.5rem 1.5rem 1.5rem 0;
            border: 1px solid #e2e8f0;
        }

        .metacrisis-glow {
            box-shadow: 0 0 20px rgba(188, 108, 37, 0.15);
            border: 1px solid rgba(188, 108, 37, 0.3);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fade { animation: fadeIn 0.4s ease-out forwards; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 glass-panel border-b border-stone-200 px-4 py-3">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div class="bg-clay-600 p-1.5 rounded-lg text-white">
                    <i data-lucide="mountain"></i>
                </div>
                <h1 class="text-xl font-bold tracking-tight">The Localization Assistant</h1>
            </div>
            <div class="hidden md:flex gap-6 text-sm font-medium text-stone-600">
                <button onclick="switchTab('explorer')" class="hover:text-clay-600 transition-colors">Study Guide</button>
                <button onclick="switchTab('assistant')" class="hover:text-clay-600 transition-colors">AI Mentor</button>
                <button onclick="switchTab('action')" class="hover:text-clay-600 transition-colors">Action Map</button>
            </div>
            <div class="bg-stone-100 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tighter text-stone-500">
                Unit 1: The Global Shadow
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-6xl mx-auto w-full p-4 md:p-8">
        
        <!-- Welcome Header -->
        <header class="mb-12 animate-fade">
            <div class="flex items-center gap-2 mb-2">
                <span class="text-clay-600 font-semibold uppercase tracking-widest text-xs">Day 1 Curriculum</span>
                <span class="h-px w-12 bg-clay-200"></span>
            </div>
            <h2 class="text-4xl md:text-5xl font-bold serif mb-4 leading-tight">The Global Shadow & The Metacrisis</h2>
            <p class="text-lg text-stone-600 max-w-3xl leading-relaxed">
                We used to say the "Elephant in the room" was our personal secrets. Today, the Elephant has grown. It is in the Town Square. We call it the <span class="text-clay-600 font-semibold italic">Metacrisis</span>.
            </p>
        </header>

        <!-- Dynamic Tabs -->
        <div id="explorer-tab" class="tab-content animate-fade">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                
                <!-- Day 1 Focused Sidebar -->
                <div class="lg:col-span-1 space-y-4">
                    <div class="glass-panel rounded-2xl p-6 shadow-sm border-2 border-clay-100">
                        <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
                            <i data-lucide="eye" class="text-clay-600"></i> Day 1 Modules
                        </h3>
                        <ul class="space-y-3">
                            <li class="p-3 bg-white rounded-xl border-l-4 border-clay-500 hover:bg-stone-50 cursor-pointer transition-all shadow-sm" onclick="showTopic('elephant')">
                                <span class="block font-semibold text-sm">The Elephant in the Square</span>
                                <span class="text-xs text-stone-500">From personal trauma to global shadow.</span>
                            </li>
                            <li class="p-3 bg-white rounded-xl border-l-4 border-stone-200 hover:border-clay-500 cursor-pointer transition-all shadow-sm" onclick="showTopic('everest')">
                                <span class="block font-semibold text-sm">The "Mount Everest" Subject</span>
                                <span class="text-xs text-stone-500">Defining the web of crises.</span>
                            </li>
                            <li class="p-3 bg-white rounded-xl border-l-4 border-stone-200 hover:border-clay-500 cursor-pointer transition-all shadow-sm" onclick="showTopic('overshoot')">
                                <span class="block font-semibold text-sm">Ecological Overshoot</span>
                                <span class="text-xs text-stone-500">The Apple Seed Metaphor.</span>
                            </li>
                            <li class="p-3 bg-white rounded-xl border-l-4 border-stone-200 hover:border-clay-500 cursor-pointer transition-all shadow-sm" onclick="showTopic('myth')">
                                <span class="block font-semibold text-sm">The Lie of Infinite Growth</span>
                                <span class="text-xs text-stone-500">Why the Elephant is tired.</span>
                            </li>
                        </ul>
                    </div>

                    <div class="glass-panel rounded-2xl p-6 shadow-sm border border-stone-200 bg-clay-50/30">
                        <h3 class="font-bold text-lg mb-2">Systems-Health Gloss</h3>
                        <div id="vocab-cloud" class="flex flex-wrap gap-2 text-xs">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                </div>

                <!-- Topic Detail Viewer -->
                <div class="lg:col-span-2 space-y-6">
                    <div id="topic-display" class="glass-panel rounded-3xl p-8 shadow-sm min-h-[550px] border border-stone-200 relative overflow-hidden">
                        <div id="default-view">
                            <div class="bg-clay-100/50 h-56 rounded-2xl mb-8 flex flex-col items-center justify-center text-clay-700 p-6 text-center">
                                <i data-lucide="alert-triangle" size="48" class="mb-4"></i>
                                <h4 class="font-bold text-xl serif italic">"We simply cannot be healthy people on a sick planet."</h4>
                            </div>
                            <h3 class="text-3xl font-bold serif mb-4">Start the Day 1 Journey</h3>
                            <p class="text-stone-600 leading-relaxed mb-6">
                                To truly dance with the Earth, we must stop running from the truth of our limits. Day 1 is about looking the Global Shadow in the eye. Select a module from the left to dive into the core foundations of the movement.
                            </p>
                            <div class="p-4 bg-stone-900 rounded-2xl text-white">
                                <p class="text-xs uppercase tracking-widest text-clay-400 mb-2 font-bold">The Day 1 Key Insight</p>
                                <p class="text-xl serif italic leading-snug">"Infinite growth on a finite planet is the lie the Elephant is tired of."</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Assistant Tab -->
        <div id="assistant-tab" class="hidden tab-content animate-fade">
            <div class="max-w-4xl mx-auto glass-panel rounded-3xl overflow-hidden shadow-lg border border-stone-200 h-[70vh] flex flex-col">
                <div class="bg-clay-600 p-4 text-white flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="bg-white/20 p-2 rounded-full">
                            <i data-lucide="bot"></i>
                        </div>
                        <div>
                            <p class="font-bold text-sm">Localization Mentor</p>
                            <p class="text-[10px] opacity-80 uppercase tracking-widest">Grounding: Day 1 - The Global Shadow</p>
                        </div>
                    </div>
                </div>
                
                <div id="chat-messages" class="flex-grow p-6 overflow-y-auto space-y-4">
                    <div class="chat-bubble-ai max-w-[85%] p-4 text-sm animate-fade">
                        Explorer, I am ready to discuss the Metacrisis. We can talk about the "Mount Everest" of subjects, the apple seed metaphor for overshoot, or why personal wellbeing now requires <span class="font-bold italic">Systems-Health</span>. Where shall we begin?
                    </div>
                </div>

                <div class="p-4 border-t border-stone-100 bg-white">
                    <form onsubmit="event.preventDefault(); sendMessage();" class="flex gap-2">
                        <input type="text" id="chat-input" placeholder="Ask about 'The Apple Seed' or 'Mount Everest analogy'..." class="flex-grow p-3 rounded-xl border border-stone-200 text-sm focus:outline-none focus:ring-2 focus:ring-clay-500">
                        <button type="submit" class="bg-clay-600 text-white p-3 rounded-xl hover:bg-clay-700 transition-colors">
                            <i data-lucide="send" size="18"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Action Map (Simplified for Day 1) -->
        <div id="action-tab" class="hidden tab-content animate-fade">
            <div class="max-w-3xl mx-auto glass-panel p-10 rounded-3xl border border-clay-200 text-center metacrisis-glow">
                <i data-lucide="shield-alert" class="mx-auto text-clay-600 mb-4" size="48"></i>
                <h3 class="text-3xl font-bold serif mb-4">Day 1 Reality Check</h3>
                <p class="text-stone-600 mb-8">Before we build, we must acknowledge. Identify one "unseen system" you rely on every day that is currently in overshoot.</p>
                
                <div class="space-y-6 text-left">
                    <div>
                        <label class="block text-sm font-bold text-stone-700 mb-2">The System (e.g., Global Food Supply, Energy Grid)</label>
                        <input type="text" placeholder="I rely on..." class="w-full p-4 rounded-xl border border-stone-200 italic">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-stone-700 mb-2">The "Apple Seed" Reflection</label>
                        <p class="text-xs text-stone-500 mb-3 italic">How is this system currently "eating the seed" (using capital) instead of "planting it" (regenerative investment)?</p>
                        <textarea class="w-full p-4 rounded-xl border border-stone-200 h-32"></textarea>
                    </div>
                    <button class="w-full bg-clay-600 text-white py-4 rounded-xl font-bold hover:bg-clay-700">Commit to the Truth</button>
                </div>
            </div>
        </div>

    </main>

    <footer class="p-8 text-center text-stone-400 text-xs border-t border-stone-100">
        <p>© 2026 Foundations of the Localization Movement | Grounded in "The Great Story"</p>
    </footer>

    <script>
        // Initialization
        const apiKey = ""; 
        
        function safeCreateIcons() {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        }

        // Deep Day 1 Content Data Store
        const topics = {
            elephant: {
                title: "Why the Elephant is in the Town Square",
                content: `
                    <div class="space-y-4">
                        <p class="text-stone-700 leading-relaxed">In the original version of our work, the <strong>Elephant</strong> represented personal secrets—the skeletons in the closet, trauma, or the denial of death. It was a private struggle.</p>
                        <div class="p-6 bg-clay-50 rounded-2xl border border-clay-200 italic">
                            "The Elephant has grown. It’s no longer just in your living room; it’s in our global town square."
                        </div>
                        <p class="text-stone-700 leading-relaxed">The shift from <strong>Self-Help</strong> to <strong>Systems-Health</strong> recognizes that personal healing is inseparable from planetary stewardship. You cannot be a healthy cell in a dying body.</p>
                        <h5 class="font-bold text-clay-700 flex items-center gap-2 mt-6">
                            <i data-lucide="move-right" size="16"></i> The Critical Pivot:
                        </h5>
                        <p class="text-sm text-stone-600 pl-6">Moving from "How do I fix my anxiety?" to "How do we heal the systems that create anxiety?"</p>
                    </div>
                `
            },
            everest: {
                title: "The 'Mount Everest' of Subjects",
                content: `
                    <div class="space-y-4">
                        <p class="text-stone-700 leading-relaxed">We call the Metacrisis the <strong>Mount Everest of subjects</strong> because it is the most daunting, complex, and high-stakes reality humanity has ever faced. It isn't just one peak; it's the entire range.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="p-4 bg-stone-50 rounded-xl border border-stone-200">
                                <h6 class="font-bold text-xs uppercase text-stone-500 mb-2">The Symptoms</h6>
                                <ul class="text-xs space-y-1 text-stone-600 list-disc pl-4">
                                    <li>Climate Instability</li>
                                    <li>Social Fragmentation</li>
                                    <li>Economic Unraveling</li>
                                    <li>Meaning Crisis</li>
                                </ul>
                            </div>
                            <div class="p-4 bg-clay-900 text-white rounded-xl">
                                <h6 class="font-bold text-xs uppercase text-clay-400 mb-2">The Core Reality</h6>
                                <p class="text-xs leading-relaxed italic">"It is the web of interconnected ecological and social failures occurring simultaneously."</p>
                            </div>
                        </div>
                    </div>
                `
            },
            overshoot: {
                title: "Ecological Overshoot: The Apple Seed",
                content: `
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="bg-red-100 p-3 rounded-full text-red-600"><i data-lucide="apple"></i></div>
                            <div>
                                <h5 class="font-bold text-lg">Eating the Seed vs. Planting It</h5>
                                <p class="text-stone-700 text-sm leading-relaxed mt-1">
                                    Ecological Overshoot means we are using nature faster than it can regenerate. In our transcripts, we describe this as <strong>"consuming our apple seed"</strong> instead of planting it for a future harvest.
                                </p>
                            </div>
                        </div>
                        <div class="bg-stone-50 p-5 rounded-2xl border-l-4 border-clay-500 italic text-stone-600 text-sm">
                            "We are currently spending from an overdrawn bank account. We are liquidating the natural capital that our grandchildren will need to survive."
                        </div>
                        <h6 class="font-bold text-sm text-clay-700">The SLURPING Sound:</h6>
                        <p class="text-xs text-stone-500">The realization that flows (energy/resources) feel infinite right up until the stock (the earth's storage) runs out. We are currently listening to that slurping sound.</p>
                    </div>
                `
            },
            myth: {
                title: "The Lie of Infinite Growth",
                content: `
                    <div class="space-y-4 text-stone-700">
                        <p class="leading-relaxed">Mainstream economics is built on the myth that we can have <strong>infinite growth on a finite planet</strong>. This is the central lie the Elephant is tired of.</p>
                        <div class="p-6 border-2 border-stone-200 rounded-3xl relative">
                            <i data-lucide="quote" class="absolute -top-3 left-6 bg-white px-2 text-clay-300"></i>
                            <p class="serif italic text-lg leading-snug">"Physical growth is a phase, not a permanent state. A child grows tall, but once they reach maturity, they stop growing taller and start growing in wisdom. Civilization has reached its physical maturity; it's time to grow deeper, not larger."</p>
                        </div>
                        <div class="flex gap-4 mt-6">
                            <div class="flex-1 p-4 bg-stone-100 rounded-xl">
                                <h6 class="text-[10px] font-bold uppercase text-stone-400 mb-1">Old Goal</h6>
                                <p class="text-xs font-bold">Accumulation & GDP</p>
                            </div>
                            <div class="flex-1 p-4 bg-clay-100 rounded-xl">
                                <h6 class="text-[10px] font-bold uppercase text-clay-600 mb-1">New Goal</h6>
                                <p class="text-xs font-bold">Systems-Health & Resilience</p>
                            </div>
                        </div>
                    </div>
                `
            }
        };

        const vocabulary = [
            "Metacrisis", "Ecological Overshoot", "Global Shadow", "Systems-Health", 
            "Self-Help", "Mount Everest Subject", "Apple Seed Metaphor", "Infinite Growth",
            "Natural Capital", "Biophysical Limits", "The Elephant", "Stock vs Flow"
        ];

        // UI Logic
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.getElementById(`${tab}-tab`).classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
            safeCreateIcons();
        }

        function showTopic(id) {
            const display = document.getElementById('topic-display');
            const topic = topics[id];
            
            display.innerHTML = `
                <div class="animate-fade">
                    <h3 class="text-3xl font-bold serif mb-6 text-clay-700">${topic.title}</h3>
                    ${topic.content}
                    <div class="mt-8 pt-6 border-t border-stone-100 flex justify-between items-center">
                        <button onclick="switchTab('assistant')" class="text-xs font-bold text-clay-600 flex items-center gap-1">
                            <i data-lucide="message-circle" size="14"></i> Ask Mentor about this
                        </button>
                        <button onclick="switchTab('action')" class="bg-stone-100 px-4 py-2 rounded-lg text-xs font-bold">Start Reality Check</button>
                    </div>
                </div>
            `;
            safeCreateIcons();
        }

        function renderVocab() {
            const cloud = document.getElementById('vocab-cloud');
            if (!cloud) return;
            cloud.innerHTML = '';
            vocabulary.forEach(v => {
                const span = document.createElement('span');
                span.className = "px-2 py-1 bg-white border border-stone-100 rounded text-stone-500 hover:border-clay-500 hover:text-clay-700 cursor-help transition-all shadow-sm";
                span.innerText = v;
                span.onclick = () => {
                    document.getElementById('chat-input').value = `Explain ${v} using the Day 1 curriculum.`;
                    switchTab('assistant');
                    sendMessage();
                };
                cloud.appendChild(span);
            });
        }

        // AI Logic
        async function sendMessage() {
            const input = document.getElementById('chat-input');
            const userText = input.value.trim();
            if (!userText) return;

            const chatBox = document.getElementById('chat-messages');
            
            const userDiv = document.createElement('div');
            userDiv.className = "flex justify-end animate-fade";
            userDiv.innerHTML = `<div class="chat-bubble-user max-w-[85%] p-4 text-sm">${userText}</div>`;
            chatBox.appendChild(userDiv);
            input.value = "";
            chatBox.scrollTop = chatBox.scrollHeight;

            const aiLoadingDiv = document.createElement('div');
            aiLoadingDiv.className = "flex justify-start animate-fade";
            aiLoadingDiv.innerHTML = `<div class="chat-bubble-ai max-w-[85%] p-4 text-sm italic text-stone-400">Consulting Day 1 transcripts...</div>`;
            chatBox.appendChild(aiLoadingDiv);
            chatBox.scrollTop = chatBox.scrollHeight;

            try {
                const response = await callGemini(userText);
                aiLoadingDiv.innerHTML = `<div class="chat-bubble-ai max-w-[85%] p-4 text-sm">${response}</div>`;
            } catch (error) {
                aiLoadingDiv.innerHTML = `<div class="chat-bubble-ai max-w-[85%] p-4 text-sm text-red-500">The local hub connection is weak. Try again.</div>`;
            }
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        async function callGemini(query, retries = 0) {
            const systemPrompt = `You are "The Localization Assistant," an AI mentor focusing on Day 1 of the Localization Movement curriculum.
            Focus: The Global Shadow, The Metacrisis, and Ecological Overshoot.
            Core Metaphors: "The Elephant in the Town Square," "The Mount Everest of subjects," "Eating the apple seed."
            Voice: Wise, conversational, grounded in systems-health. 
            Mandate: Contrast "Self-Help" with "Systems-Health." If someone asks about personal anxiety, pivot to how it is a symptom of the Metacrisis. 
            Explain why "Infinite Growth" is impossible.`;
            
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            
            const payload = {
                contents: [{ parts: [{ text: query }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                if (!response.ok) throw new Error('API Error');
                const result = await response.json();
                return result.candidates?.[0]?.content?.parts?.[0]?.text || "I'm searching the archives for that specific Day 1 insight...";
            } catch (err) {
                if (retries < 5) {
                    const delay = Math.pow(2, retries) * 1000;
                    await new Promise(res => setTimeout(res, delay));
                    return callGemini(query, retries + 1);
                }
                throw err;
            }
        }

        // Init
        document.addEventListener('DOMContentLoaded', () => {
            const checkLucide = setInterval(() => {
                if (typeof lucide !== 'undefined') {
                    lucide.createIcons();
                    renderVocab();
                    clearInterval(checkLucide);
                }
            }, 100);
            setTimeout(() => clearInterval(checkLucide), 5000);
        });
    </script>
</body>
</html>
